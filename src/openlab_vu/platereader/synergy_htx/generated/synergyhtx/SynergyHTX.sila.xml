      <Identifier>PlateID</Identifier>
      <DisplayName>Plate ID</DisplayName>
      <Description>Plate ID</Description>
      <DataType>
        <Basic>Integer</Basic>
      </DataType>
    </Parameter>
    <Response>
      <Identifier>PlateID</Identifier>
      <DisplayName>Plate ID</DisplayName>
      <Description>Plate ID</Description>
      <DataType>
        <Basic>Integer</Basic>
      </DataType>
    </Response>
  </Command>
  <Command>
    <Identifier>RemovePlate</Identifier>
    <DisplayName>Remove a plate from the device</DisplayName>
    <Description>Remove a plate from the device</Description>
    <Observable>No</Observable>
