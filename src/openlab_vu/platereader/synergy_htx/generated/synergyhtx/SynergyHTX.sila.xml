    <DisplayName>Read the device temperature</DisplayName>
    <Description>Read the device temperature</Description>
    <Observable>No</Observable>
    <Response>
      <Identifier>DeviceTemperature</Identifier>
      <DisplayName>Device temperature</DisplayName>
      <Description>Temperature reported by the device</Description>
      <DataType>
        <Basic>Real</Basic>
      </DataType>
    </Response>
  </Command>
