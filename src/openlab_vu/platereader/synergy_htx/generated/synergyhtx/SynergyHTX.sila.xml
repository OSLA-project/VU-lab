<Feature xmlns="http://www.sila-standard.org" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" Category="platereaders" FeatureVersion="1.0" MaturityLevel="Verified" Originator="org.silastandard" SiLA2Version="1.0" xsi:schemaLocation="http://www.sila-standard.org https://gitlab.com/SiLA2/sila_base/raw/master/schema/FeatureDefinition.xsd">
  <Identifier>SynergyHTX</Identifier>
  <DisplayName>Biotek Synergy HTX SiLA Server</DisplayName>
  <Description>SiLA server for the Biotek Synergy HTX plate reader</Description>
  <Command>
    <Identifier>OpenTray</Identifier>
    <DisplayName>Open the tray</DisplayName>
    <Description>Opens the tray of the plate reader</Description>
    <Observable>No</Observable>
    <Response>
      <Identifier>TrayState</Identifier>
      <DisplayName>Tray state</DisplayName>
      <Description>State of the tray after the command</Description>
      <DataType>
        <Basic>String</Basic>
      </DataType>
    </Response>
  </Command>
  <Command>
    <Identifier>CloseTray</Identifier>
    <DisplayName>Close the tray</DisplayName>
    <Description>Closes the tray of the plate reader</Description>
    <Observable>No</Observable>
    <Response>
      <Identifier>TrayState</Identifier>
      <DisplayName>Tray state</DisplayName>
      <Description>State of the tray after the command</Description>
      <DataType>
        <Basic>String</Basic>
      </DataType>
    </Response>
  </Command>
  <Command>
